{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wendy.sh/schemas/wendy.json",
  "title": "Wendy App Configuration",
  "description": "Configuration file for Wendy edge computing applications (wendy.json).",
  "type": "object",
  "required": ["appId"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema reference for editor support."
    },
    "appId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[a-zA-Z0-9._-]+$",
      "description": "Unique application identifier. Only letters, digits, '.', '_', and '-' are allowed."
    },
    "version": {
      "type": "string",
      "description": "Application version string (e.g. \"0.1.0\")."
    },
    "platform": {
      "type": "string",
      "enum": ["wendyos", "wendy-lite", "darwin"],
      "description": "Target platform: wendyos (Linux edge devices), wendy-lite (ESP32 WASM), or darwin (native macOS via Wendy Agent for Mac)."
    },
    "language": {
      "type": "string",
      "description": "Project language (e.g. \"swift\", \"python\")."
    },
    "debug": {
      "type": "boolean",
      "default": false,
      "description": "Enable debug mode."
    },
    "entitlements": {
      "type": "array",
      "description": "Capabilities the app requires (GPU, network, Bluetooth, etc.).",
      "items": {
        "$ref": "#/$defs/entitlement"
      }
    },
    "readiness": {
      "$ref": "#/$defs/readiness"
    },
    "hooks": {
      "$ref": "#/$defs/hooks"
    },
    "python": {
      "$ref": "#/$defs/python"
    },
    "run": {
      "$ref": "#/$defs/run"
    },
    "files": {
      "type": "array",
      "description": "Files or directories to sync to the device before the app starts.",
      "items": {
        "$ref": "#/$defs/fileSyncEntry"
      }
    }
  },
  "$defs": {
    "entitlement": {
      "type": "object",
      "required": ["type"],
      "description": "A single app entitlement granting access to a device capability.",
      "oneOf": [
        {
          "properties": {
            "type": { "const": "network" },
            "mode": {
              "type": "string",
              "enum": ["host", "none"],
              "description": "Network mode. \"host\" shares the host network stack; \"none\" disables networking."
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "bluetooth" },
            "mode": {
              "type": "string",
              "description": "Bluetooth access mode."
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "deprecated": true,
          "description": "Deprecated: use the camera entitlement instead.",
          "properties": {
            "type": {
              "const": "video",
              "deprecated": true,
              "description": "Deprecated: use \"camera\" instead."
            },
            "mode": {
              "type": "string",
              "description": "Video access mode."
            },
            "allowlist": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed video device paths."
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "gpu" }
          },
          "required": ["type"],
          "additionalProperties": false,
          "description": "GPU access for AI inference or compute."
        },
        {
          "properties": {
            "type": { "const": "persist" },
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "App ID — a shared namespace. Apps with the same ID can access each other's data."
            },
            "path": {
              "type": "string",
              "minLength": 1,
              "description": "Mount path inside the container (e.g. \"/data\")."
            }
          },
          "required": ["type", "name", "path"],
          "additionalProperties": false,
          "description": "Persistent storage that survives container restarts."
        },
        {
          "properties": {
            "type": { "const": "audio" }
          },
          "required": ["type"],
          "additionalProperties": false,
          "description": "Microphone and speaker access."
        },
        {
          "properties": {
            "type": { "const": "camera" },
            "mode": {
              "type": "string",
              "description": "Camera access mode. Accepted for compatibility with the deprecated video entitlement."
            },
            "allowlist": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed camera device paths. Accepted for compatibility with the deprecated video entitlement."
            }
          },
          "required": ["type"],
          "additionalProperties": false,
          "description": "Camera/V4L2 device access. Legacy video entitlement keys remain accepted for compatibility."
        },
        {
          "properties": {
            "type": { "const": "usb" }
          },
          "required": ["type"],
          "additionalProperties": false,
          "description": "USB device access."
        },
        {
          "properties": {
            "type": { "const": "i2c" },
            "device": {
              "type": "string",
              "minLength": 1,
              "description": "I2C device path (e.g. \"/dev/i2c-1\")."
            }
          },
          "required": ["type", "device"],
          "additionalProperties": false,
          "description": "I2C bus device access."
        },
        {
          "properties": {
            "type": { "const": "gpio" },
            "pins": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0
              },
              "description": "GPIO pin numbers. Omit to grant access to all GPIO chips."
            }
          },
          "required": ["type"],
          "additionalProperties": false,
          "description": "General-purpose I/O pin access."
        },
        {
          "properties": {
            "type": { "const": "spi" }
          },
          "required": ["type"],
          "additionalProperties": false,
          "description": "SPI device access."
        },
        {
          "properties": {
            "type": { "const": "input" }
          },
          "required": ["type"],
          "additionalProperties": false,
          "description": "HID input device access (barcode scanners, keyboards, etc.)."
        }
      ]
    },
    "readiness": {
      "type": "object",
      "description": "Probe configuration the CLI uses to determine when the app is ready.",
      "additionalProperties": false,
      "properties": {
        "tcpSocket": {
          "type": "object",
          "description": "Check readiness by dialing a TCP port.",
          "required": ["port"],
          "additionalProperties": false,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "description": "TCP port to probe."
            }
          }
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 0,
          "default": 30,
          "description": "Readiness timeout in seconds (default 30)."
        }
      }
    },
    "hooks": {
      "type": "object",
      "description": "Lifecycle hook commands.",
      "additionalProperties": false,
      "properties": {
        "postStart": {
          "$ref": "#/$defs/hookCommand"
        }
      }
    },
    "hookCommand": {
      "type": "object",
      "description": "Commands to run at a lifecycle stage.",
      "additionalProperties": false,
      "properties": {
        "openURL": {
          "type": "string",
          "format": "uri",
          "description": "URL to open in the developer's default browser. Cross-platform; prefer this over a `cli` shell invocation of `open`/`xdg-open`/`start`. Supports ${WENDY_HOSTNAME} and ${WENDY_APP_ID} expansion."
        },
        "cli": {
          "type": "string",
          "description": "Command to run on the developer's machine. Note: `open`/`xdg-open`/`start` are not portable across macOS/Linux/Windows — use `openURL` to open a URL instead."
        },
        "agent": {
          "type": "string",
          "description": "Command to run on the device."
        }
      }
    },
    "fileSyncEntry": {
      "type": "object",
      "description": "A file or directory to sync to the device's app working directory.",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*\\.\\./|.*\\/\\.\\.$|^\\.\\.$)",
          "description": "Source path relative to wendy.json (file or directory)."
        },
        "to": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*\\.\\./|.*\\/\\.\\.$|^\\.\\.$)",
          "description": "Destination path relative to the app working directory. Defaults to path with any leading ./ stripped."
        }
      }
    },
    "python": {
      "type": "object",
      "description": "Python-specific configuration.",
      "additionalProperties": false,
      "properties": {
        "sourceRoot": {
          "type": "string",
          "description": "Path to the Python source root directory."
        }
      }
    },
    "run": {
      "type": "object",
      "description": "Runtime configuration applied when the app is started.",
      "additionalProperties": false,
      "properties": {
        "args": {
          "type": "array",
          "description": "Command-line arguments passed directly to the app executable.",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}

