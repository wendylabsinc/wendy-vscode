{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "appId": {
            "type": "string",
            "description": "Unique identifier for the application"
        },
        "version": {
            "type": "string",
            "description": "Version of the application"
        },
        "language": {
            "type": "string",
            "enum": [
                "python",
                "swift"
            ],
            "description": "Programming language of the project"
        },
        "python": {
            "type": "object",
            "description": "Python-specific configuration",
            "properties": {
                "container": {
                    "type": "object",
                    "properties": {
                        "sourceRoot": {
                            "type": "string",
                            "description": "The directory in the container where the Python source code is located."
                        }
                    }
                }
            }
        },
        "entitlements": {
            "type": "array",
            "description": "List of entitlements required by the application",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "network",
                            "video",
                            "audio",
                            "bluetooth",
                            "gpu",
                            "persist"
                        ],
                        "description": "The type of entitlement."
                    }
                },
                "required": [
                    "type"
                ],
                "oneOf": [
                    {
                        "type": "object",
                        "required": [
                            "type",
                            "mode"
                        ],
                        "description": "Define access to the network.",
                        "properties": {
                            "type": {
                                "type": "string",
                                "const": "network"
                            },
                            "mode": {
                                "type": "string",
                                "enum": [
                                    "host",
                                    "none"
                                ],
                                "description": "Network mode - 'host' allows full network access, 'none' disables all network access"
                            }
                        }
                    },
                    {
                        "type": "object",
                        "required": [
                            "type"
                        ],
                        "description": "Define access to camera/video devices.",
                        "properties": {
                            "type": {
                                "type": "string",
                                "const": "video"
                            }
                        }
                    },
                    {
                        "type": "object",
                        "required": [
                            "type"
                        ],
                        "description": "Define access to audio devices.",
                        "properties": {
                            "type": {
                                "type": "string",
                                "const": "audio"
                            }
                        }
                    },
                    {
                        "type": "object",
                        "required": [
                            "type"
                        ],
                        "description": "Define access to Bluetooth devices.",
                        "properties": {
                            "type": {
                                "type": "string",
                                "const": "bluetooth"
                            }
                        }
                    },
                    {
                        "type": "object",
                        "required": [
                            "type"
                        ],
                        "description": "Define access to GPU for hardware acceleration.",
                        "properties": {
                            "type": {
                                "type": "string",
                                "const": "gpu"
                            }
                        }
                    },
                    {
                        "type": "object",
                        "required": [
                            "type",
                            "name",
                            "path"
                        ],
                        "description": "Define a persistent volume for data that survives app restarts.",
                        "properties": {
                            "type": {
                                "type": "string",
                                "const": "persist"
                            },
                            "name": {
                                "type": "string",
                                "description": "Name of the persistent volume"
                            },
                            "path": {
                                "type": "string",
                                "description": "Path inside the container where the volume is mounted"
                            }
                        }
                    }
                ]
            }
        }
    },
    "required": [
        "appId",
        "version",
        "entitlements"
    ]
}
